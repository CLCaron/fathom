# Database URL (SQLite by default, change to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/signals.db

# SEC EDGAR requires a User-Agent with your name and email
SEC_EDGAR_USER_AGENT=financial-signals your-email@example.com

# Minimum confidence score to store a signal (0-100)
MIN_CONFIDENCE=25

# Server settings
HOST=127.0.0.1
PORT=8000
